# =============================================================================
# Security / Secrets (NEVER commit)
# =============================================================================
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.truststore
.htpasswd
.htaccess
credentials.json
secrets.json
secret_key_base
config/secrets.yml
config/credentials.yml.enc
config/master.key
.id_rsa
id_ed25519
id_rsa
known_hosts
authorized_keys
.ssh/
.aws/credentials
.azure/
.gcp/

# =============================================================================
