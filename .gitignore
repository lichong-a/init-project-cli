# =============================================================================
# Universal .gitignore
# Covers: Node.js, Python, Java, Go, Rust, C/C++, .NET, Ruby, PHP, Swift,
#         Kotlin, Scala, Dart/Flutter, Elixir, Haskell, and common process artifacts
# =============================================================================

# =============================================================================
# Process / Temporary (项目过程产物)
# =============================================================================
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
*.orig
*.rej

# =============================================================================
# OS Generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.directory

# =============================================================================
# Editor / IDE
# =============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# JetBrains (IntelliJ / WebStorm / GoLand / PyCharm / RustRover ...)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.un~
Session.vim
.netrwhist
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
auto-save-list
tramp
.\#*
*.elc

# Sublime Text
*.sublime-workspace
*.sublime-project
*.stTheme.cache
*.tmTheme.cache

# Cursor
.cursor/

# Zed
.zed/

# =============================================================================
# Node.js / JavaScript / TypeScript
# =============================================================================
node_modules/
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo
.npmrc (if contains tokens)

# Build output
dist/
build/
out/
.output/
.nuxt/
.next/
.svelte-kit/
.vercel/
.netlify/
.aws/
.cloudflare/

# Framework specific
.angular/
.vuepress/dist/
.docusaurus/
.serverless/
.fusebox/
.stryker-tmp/
.nyc_output/
coverage/

# Bundler cache
.vite/
.turbo/
.webpack/
.rollup.cache/
.parcel-cache/
.esbuild/

# Package lock (keep one, ignore others based on project)
# pnpm-lock.yaml  # uncomment if using yarn
# yarn.lock        # uncomment if using pnpm
# package-lock.json # uncomment if using pnpm/yarn

